# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://your-user:your-password@cluster.mongodb.net/readreceipt?retryWrites=true&w=majority

# Gmail SMTP for email reminders  
# To get an App Password: Google Account > Security > 2-Step Verification > App passwords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Secret for the cron endpoint (generate a random string)
CRON_SECRET=change-me-to-a-random-secret

# Base URL (set to your Vercel URL in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
